200  STACK_PUSH  # Y
2    STACK_PUSH  # Width
600  STACK_PUSH  # Height
0    STACK_PUSH  # R
255  STACK_PUSH  # G
255  STACK_PUSH  # B
GUI_DRAW_RECT

"[WM] Genesis Wireframe Window 1 Drawn at (300,200)." 𐡐

# ============================================================
# 2. DRAW WINDOW TITLE BAR (Minimalist White Text)
# ============================================================
