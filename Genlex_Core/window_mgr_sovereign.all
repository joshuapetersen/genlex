200  STACK_PUSH  # Y
800  STACK_PUSH  # Width
2    STACK_PUSH  # Height
0    STACK_PUSH  # R
255  STACK_PUSH  # G
255  STACK_PUSH  # B
GUI_DRAW_RECT

# Bottom Border
300  STACK_PUSH  # X
798  STACK_PUSH  # Y (200 + 600 - 2)
800  STACK_PUSH  # Width
2    STACK_PUSH  # Height
0    STACK_PUSH  # R
255  STACK_PUSH  # G
255  STACK_PUSH  # B
GUI_DRAW_RECT

# Left Border
