NVME_QUEUE_INIT   # Initialize submission/completion queues
NVME_SUBMIT       # Submit NVMe command to hardware queue
NVME_COMPLETE     # Process NVMe completion queue
NVME_READ         # Read sectors from NVMe SSD (direct)
NVME_WRITE        # Write sectors to NVMe SSD (direct)
NVME_FLUSH        # Flush NVMe write cache
NVME_TRIM         # TRIM command (mark deleted blocks)
NVME_POWER        # NVMe power management
