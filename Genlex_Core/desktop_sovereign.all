1045 STACK_PUSH  # Y
80   STACK_PUSH  # Width
30   STACK_PUSH  # Height
0    STACK_PUSH  # R
200  STACK_PUSH  # G
255  STACK_PUSH  # B
GUI_DRAW_RECT

# Write "SARAH" text inside the button in high-contrast white
22   STACK_PUSH  # X offset
1052 STACK_PUSH  # Y offset
"SARAH" STACK_PUSH
255  STACK_PUSH  # Text R
255  STACK_PUSH  # Text G
255  STACK_PUSH  # Text B
GUI_DRAW_TEXT

"[GUI] SARAH Root Menu button rendered." 𐡐

