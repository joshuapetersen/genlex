𒀸 ⚡ [DRAW_BACKGROUND]
# Clear the 1920x1080 screen to Pitch Black (The Sovereign Void)
0    STACK_PUSH  # R
0    STACK_PUSH  # G
0    STACK_PUSH  # B
GUI_CLEAR_SCREEN

"[GUI] Screen cleared to Sovereign Void (Black)." 𐡐

# ============================================================
# 2. DRAW THE TASKBAR (Bottom 40 pixels)
# ============================================================
𒀸 ⚡ [DRAW_TASKBAR]
0    STACK_PUSH  # X Start
1040 STACK_PUSH  # Y Start (1080 - 40)
1920 STACK_PUSH  # Width
40   STACK_PUSH  # Height
5    STACK_PUSH  # R
5    STACK_PUSH  # G
5    STACK_PUSH  # B
GUI_DRAW_RECT

# Draw a 2-pixel glowing Sovereign Cyan accent line at the top of the taskbar
0    STACK_PUSH  # X
1040 STACK_PUSH  # Y
1920 STACK_PUSH  # Width
2    STACK_PUSH  # Height
0    STACK_PUSH  # R
255  STACK_PUSH  # G
255  STACK_PUSH  # B
GUI_DRAW_RECT

"[GUI] Base Taskbar rendered (Y: 1040 to 1080)." 𐡐

# ============================================================
# 3. DRAW THE "START" BUTTON (The AERIS Root Menu)
# ============================================================
𒀸 ⚡ [DRAW_START_MENU_BUTTON]
# Draw a hollow glowing cyan outline for the button
